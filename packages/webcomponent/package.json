{
  "name": "@markview/webcomponent",
  "version": "0.1.0",
  "description": "Web Component for beautiful markdown rendering — works in any framework or plain HTML",
  "license": "Apache-2.0",
  "author": "Ahmet Barış Günaydın <hi@barisgunaydin.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/abgnydn/markview",
    "directory": "packages/webcomponent"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@markview/core": ">=0.1.0"
  },
  "peerDependenciesMeta": {
    "shiki": {
      "optional": true
    },
    "mermaid": {
      "optional": true
    },
    "katex": {
      "optional": true
    }
  },
  "devDependencies": {
    "@markview/core": "file:../core",
    "@markview/tsconfig": "file:../tsconfig",
    "@types/katex": "^0.16",
    "katex": "^0.16",
    "mermaid": "^11.15.0",
    "shiki": "^4",
    "typescript": "^5"
  },
  "keywords": [
    "web-component",
    "custom-element",
    "markdown",
    "viewer",
    "renderer",
    "vue",
    "angular",
    "svelte",
    "shiki",
    "mermaid",
    "katex"
  ]
}
