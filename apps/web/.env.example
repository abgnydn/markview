# Environment Variables for MarkView Web App
# Copy this file to .env.local for local development

# ─── Collaboration (y-webrtc) ─────────────────────────────────────────────────
# y-webrtc requires a WebRTC signaling server to establish peer connections.
#
# Options:
#   1. Use the default public server (NOT recommended for production):
#      wss://signaling.yjs.dev
#   2. Self-host: https://github.com/yjs/y-webrtc#signaling
#
NEXT_PUBLIC_YJS_SIGNALING_SERVER=wss://signaling.yjs.dev

