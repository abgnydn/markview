# Environment Variables for MarkView Web App
# Copy this file to .env.local for local development

# ─── Error Monitoring (Sentry) ────────────────────────────────────────────────
# Required for source map uploads (enables readable stack traces in Sentry).
# Get your token: https://sentry.io/settings/markview/developer-settings/
# Add to: Vercel env vars + GitHub Actions secret "SENTRY_AUTH_TOKEN"
# DO NOT commit the real token — .env.local is already in .gitignore
SENTRY_AUTH_TOKEN=

# ─── Collaboration (y-webrtc) ─────────────────────────────────────────────────
# y-webrtc requires a WebRTC signaling server to establish peer connections.
#
# Options:
#   1. Use the default public server (NOT recommended for production):
#      wss://signaling.yjs.dev
#   2. Self-host: https://github.com/yjs/y-webrtc#signaling
#
NEXT_PUBLIC_YJS_SIGNALING_SERVER=wss://signaling.yjs.dev

