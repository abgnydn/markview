{
  "name": "@markview/mcp",
  "version": "0.1.0",
  "description": "MCP server for MarkView — expose markdown documentation to AI assistants. Run: npx @markview/mcp ./docs",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "markview-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "markdown",
    "documentation",
    "ai",
    "model-context-protocol",
    "claude",
    "cursor",
    "markview"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/abgnydn/markview.git",
    "directory": "apps/mcp"
  },
  "homepage": "https://github.com/abgnydn/markview/tree/main/apps/mcp",
  "author": "Ahmet Barış Günaydın",
  "license": "AGPL-3.0",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^4.1.0",
    "@markview/tsconfig": "file:../../packages/tsconfig"
  }
}
