{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MarkView",
  "version": "0.1.0",
  "identifier": "com.markview.desktop",
  "build": {
    "frontendDist": "../../web/out",
    "devUrl": "http://localhost:3001",
    "beforeDevCommand": "cd ../web && npm run dev -- --port 3001"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "MarkView",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "center": true
      }
    ],
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "12.0",
      "infoPlist": "./Info.plist"
    }
  }
}
