# Environment Variables for MarkView Web App
# Copy this file to .env.local for local development

# ─── Collaboration (y-webrtc) ─────────────────────────────────────────────────
# y-webrtc requires a WebRTC signaling server to establish peer connections.
#
# Options:
#   1. Use the default public server (NOT recommended for production):
#      wss://signaling.yjs.dev
#   2. Self-host: https://github.com/yjs/y-webrtc#signaling
#
NEXT_PUBLIC_YJS_SIGNALING_SERVER=wss://signaling.yjs.dev

# ─── Landing surface ──────────────────────────────────────────────────────────
# `/` shows two different landing pages depending on which audience we're
# serving. Both run from the same build.
#
#   editor → markview.ai — markdown-editor-focused hero (LandingEditor)
#   app    → brain.markview.ai — cosmic vault/brain hero (LandingAtlas, default)
#
# NEXT_PUBLIC_SURFACE=editor

# ─── Temple route gate ────────────────────────────────────────────────────────
# /temple is the experimental "visit Claude in 3D" surface. It depends on
# the apps/hub speak bridge running on :3100 and a local `claude` CLI.
# Public builds omit it entirely (route 404s, three.js bundle tree-shaken).
# Set this to "1" in .env.local for local development.
#
# NEXT_PUBLIC_TEMPLE_ENABLED=1

