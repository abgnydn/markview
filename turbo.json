{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "out/**", ".next/**", "!.next/cache/**"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "lint": {
      "outputs": []
    },
    "type-check": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "dev": {
      "persistent": true,
      "cache": false
    },
    "size": {
      "dependsOn": ["build"],
      "outputs": []
    },
    "apps-extension#build": {
      "dependsOn": ["web#build"],
      "outputs": ["app/**"]
    },
    "desktop#build": {
      "dependsOn": ["web#build"],
      "outputs": ["src-tauri/target/**"]
    }
  }
}
