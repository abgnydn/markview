{
  "name": "markview",
  "version": "1.0.0",
  "description": "Beautiful, privacy-first markdown documentation viewer with MCP tools for AI assistants",
  "author": "Ahmet Barış Günaydın <abgunaydin94@gmail.com>",
  "license": "AGPL-3.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/abgnydn/markview"
  },
  "homepage": "https://github.com/abgnydn/markview",
  "bugs": {
    "url": "https://github.com/abgnydn/markview/issues"
  },
  "keywords": [
    "markdown",
    "viewer",
    "documentation",
    "mcp",
    "model-context-protocol",
    "chrome-extension",
    "next.js",
    "privacy-first",
    "offline",
    "mermaid",
    "katex",
    "shiki"
  ],
  "private": true,
  "scripts": {
    "build": "npm run build:core && npm run build:web",
    "build:core": "cd packages/core && npm run build",
    "build:web": "cd apps/web && npm run build",
    "test": "cd apps/web && npm test",
    "lint": "cd apps/web && npm run lint",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.2.0",
    "lint-staged": "^16.1.0"
  },
  "lint-staged": {
    "apps/web/src/**/*.{ts,tsx}": [
      "eslint --fix --no-warn-ignored"
    ],
    "packages/core/src/**/*.ts": [
      "eslint --fix --no-warn-ignored"
    ]
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
