{
  "name": "@markview/mcp",
  "version": "0.1.0",
  "description": "MCP server for MarkView — read, search, and edit your local markdown vault from any AI tool (Claude Desktop, Cursor, Zed). 23 tools incl. graph queries. Run: npx @markview/mcp ./vault",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "markview-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "markdown",
    "documentation",
    "ai",
    "model-context-protocol",
    "claude",
    "cursor",
    "markview"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/abgnydn/markview.git",
    "directory": "apps/mcp"
  },
  "homepage": "https://github.com/abgnydn/markview/tree/main/apps/mcp",
  "author": "Ahmet Barış Günaydın",
  "license": "Apache-2.0",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "werift": "^0.22.9",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@markview/tsconfig": "file:../../packages/tsconfig",
    "@types/node": "^25.5.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^4.1.0"
  }
}
