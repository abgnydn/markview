{
  "name": "markview",
  "version": "1.0.0",
  "description": "Beautiful, privacy-first markdown documentation viewer with MCP tools for AI assistants",
  "author": "Ahmet Barış Günaydın <abgunaydin94@gmail.com>",
  "license": "AGPL-3.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/abgnydn/markview"
  },
  "homepage": "https://github.com/abgnydn/markview",
  "bugs": {
    "url": "https://github.com/abgnydn/markview/issues"
  },
  "keywords": [
    "markdown",
    "viewer",
    "documentation",
    "mcp",
    "model-context-protocol",
    "chrome-extension",
    "next.js",
    "privacy-first",
    "offline",
    "mermaid",
    "katex",
    "shiki"
  ],
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "build:core": "cd packages/core && npm run build",
    "build:web": "cd apps/web && npm run build",
    "desktop:dev": "cd apps/desktop && npm run dev",
    "desktop:build": "cd apps/desktop && npm run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "changeset": "changeset",
    "release": "changeset publish",
    "prepare": "husky || true"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.10",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "turbo": "^2.5.3"
  },
  "lint-staged": {
    "apps/web/src/**/*.{ts,tsx}": [
      "bash -c 'cd apps/web && npx next lint --fix --file $(echo \"$1\" | sed \"s|apps/web/||g\")' --"
    ],
    "packages/core/src/**/*.ts": [
      "bash -c 'cd packages/core && npx tsc --noEmit'"
    ]
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
